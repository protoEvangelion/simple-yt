{
  "name": "simple-yt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview --port 3000",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --react-plugin --import-plugin .",
    "format": "oxfmt --ignore-path .oxfmtignore --check src README.md package.json tsconfig.json vite.config.ts tailwind.config.ts",
    "format:write": "oxfmt --ignore-path .oxfmtignore src README.md package.json tsconfig.json vite.config.ts tailwind.config.ts",
    "check": "bun run format && bun run lint && bun run typecheck"
  },
  "dependencies": {
    "@heroui/react": "^2.6.14",
    "@heroui/theme": "^2.4.26",
    "@tanstack/react-router": "^1.168.22",
    "@tanstack/react-start": "^1.167.41",
    "framer-motion": "^11.18.1",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "youtube-sr": "^4.3.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tailwindcss": "^4.1.18",
    "typescript": "beta",
    "vite": "^8.0.0"
  }
}
